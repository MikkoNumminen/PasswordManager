# Build output
/target

# Vault and server databases: local data, never committed.
*.db
*.db-wal
*.db-shm
*.db-journal
*.sqlite
*.sqlite3

# Secrets and local configuration. Tunnel tokens and OAuth secrets live in
# Cloudflare or environment variables, never in this repository.
.env
.env.*
*.pem
*.key
*.p12
.cloudflared/
*tunnel-token*
credentials*.json

# Generated by wasm-bindgen; rebuild per README.
/web/static/pkg/

# Extension build output: wasm bindings and the downloaded public suffix list.
/extension/vendor/
/extension/node_modules/

# Local scratch (pasted screenshots etc.)
/.local/
